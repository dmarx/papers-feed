  margin-bottom: 16px;
  border-left: 2px solid #f0f0f0;
  padding-left: 8px;
  color: #444;
  max-height: 150px;
  overflow-y: auto;
}

.paper-popup-actions {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.paper-action-button {
  flex: 1;
  padding: 8px;
  border: 1px solid #ddd;
  border-radius: 4px;
  background: #f5f5f5;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.paper-action-button:hover {
  background: #e5e5e5;
}

.paper-action-button.active {
  background: #e3f2fd;
  border-color: #2196F3;
}

.paper-notes {
  width: 100%;
  height: 80px;
  border: 1px solid #ddd;
  border-radius: 4px;
  padding: 8px;
  margin-bottom: 12px;
  font-family: inherit;
  font-size: 13px;
  resize: vertical;
}

.paper-save-button {
  background-color: #4285F4;
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 500;
  float: right;
  transition: background-color 0.2s ease;
}

.paper-save-button:hover {
  background-color: #1A73E8;
}

/* Toast notification */
.paper-toast {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 8px 16px;
  border-radius: 4px;
  font-family: system-ui, -apple-system, sans-serif;
  font-size: 14px;
  z-index: 10000;
  animation: fadeInOut 3s ease-in-out;
}

/* Source-specific styling */
[class*="source-arxiv"] {
  background-color: #B31B1B !important;
}

[class*="source-semanticscholar"] {
  background-color: #2e7d32 !important;
}

[class*="source-doi"], [class*="source-acm"] {
  background-color: #0277bd !important;
}

[class*="source-openreview"] {
  background-color: #6d4c41 !important;
}



