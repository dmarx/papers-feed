  handleGetPluginExtractor(pluginId: string, sendResponse: (response: any) => void): void {
    try {
      const extractorCode = urlDetectionService.getExtractorInfoForPlugin(pluginId);
      
      if (extractorCode) {
        sendResponse({
          success: true,
          extractorCode
        });
      } else {
        sendResponse({
