        urlPatterns: [
            /arxiv\.org\/abs\/([0-9.]+)/,
            /arxiv\.org\/pdf\/([0-9.]+)\.pdf/,
            /arxiv\.org\/\w+\/([0-9.]+)/
        ],
        getIdFromMatch: (match) => match[1]
    },
    {
        type: 'doi',
        urlPatterns: [
            /doi\.org\/(10\.[0-9.]+\/[a-zA-Z0-9._\-/:()\[\]]+)/
        ],
        getIdFromMatch: (match) => match[1]
    },
    {
        type: 'acm',
        urlPatterns: [
            /dl\.acm\.org\/doi\/(10\.[0-9.]+\/[a-zA-Z0-9._\-/:()\[\]]+)/
        ],
