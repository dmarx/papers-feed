      !(e.target as HTMLElement).closest('.paper-popup') && 
      !(e.target as HTMLElement).closest('.paper-annotator')
    ) {
      // Get all popup containers and remove them
      document.querySelectorAll('.paper-popup-container').forEach(container => {
