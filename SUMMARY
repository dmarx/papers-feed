}

.papers-container-inner {
    overflow: hidden;
}

.collapsed .papers-container {
    grid-template-rows: 0fr;
}

/* Table Layout */
.papers-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.875rem;
}

.papers-table tr {
    cursor: pointer;
    transition: background-color 0.2s ease;
