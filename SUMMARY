/* frontend/src/styles/papers.css */
.day-group {
    margin-bottom: 1.5rem;
}

.day-header {
    background: var(--accent-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
